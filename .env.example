# ---------------------------------------------------------------------------
# payments-service example configuration.
# Copy to .env and fill in real values. NEVER commit a real .env (gitignored).
# No secret is ever hardcoded in source — every value is read from here.
# ---------------------------------------------------------------------------

# Server
PORT=8080
ENV=development               # development | production
LOG_LEVEL=info                # debug | info | warn | error

# Database — never use a superuser in app; use the least-privilege payments_app role.
# Production: sslmode=require. Development against a local Postgres may use
# sslmode=disable (only acceptable when ENV=development).
DATABASE_URL=postgres://payments_app:strongpassword@localhost:5432/payments?sslmode=require
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# JWT — access + refresh use SEPARATE secrets, each >= 32 chars.
JWT_ACCESS_SECRET=change_me_min_32_chars_access_xxxxx
JWT_REFRESH_SECRET=change_me_min_32_chars_refresh_xxxx
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# API Keys — HMAC-SHA256 secret used to hash keys at rest (>= 32 chars).
API_KEY_HMAC_SECRET=change_me_min_32_chars_apikey_xxxxx

# Redis (rate limiting + idempotency cache)
REDIS_URL=redis://localhost:6379

# Stripe (optional in development)
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plaid (optional in development)
PLAID_CLIENT_ID=...
PLAID_SECRET_LIVE=...
PLAID_SECRET_SANDBOX=...
PLAID_ENV=sandbox             # sandbox | development | production

# Webhook delivery
WEBHOOK_SIGNING_SECRET=change_me_min_32_chars_webhook_xxxx
WEBHOOK_DELIVERY_RETRIES=5
WEBHOOK_RETRY_BACKOFF_SECONDS=60

# Rate limits (requests per minute per key)
RATE_LIMIT_LIVE_RPM=1000
RATE_LIMIT_TEST_RPM=100
RATE_LIMIT_DASHBOARD_RPM=300

# CORS — comma-separated allowlist of dashboard origins (empty = none allowed)
ALLOWED_ORIGINS=http://localhost:3000

# Client IP source. Set true ONLY behind a proxy/LB that always appends the
# real client IP to X-Forwarded-For; otherwise clients can spoof their IP
# (per-IP rate-limit evasion, polluted audit logs). Default: false (TCP peer).
TRUST_PROXY_HEADERS=false

# ---------------------------------------------------------------------------
# Docker Compose only — passwords for the provisioned database roles. The init
# script creates payments_app + payments_migrations with these; the compose
# api/migrate services build their connection strings from them. (Compose has
# built-in fallbacks, but set real values here for anything but throwaway dev.)
# ---------------------------------------------------------------------------
POSTGRES_SUPERUSER_PASSWORD=postgres
PAYMENTS_APP_PASSWORD=app_password
PAYMENTS_MIGRATIONS_PASSWORD=migrations_password
